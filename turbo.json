{
  "$schema": "https://v2-9-12.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".playground/.output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["PLAYGROUND_LAYERS"]
    },
    "lint": {}
    // "typecheck": {
    //   "dependsOn": ["^typecheck"]
    // }
  }
}
