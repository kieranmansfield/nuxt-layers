{
  "extends": "./apps/playground/.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },

  "include": [
    "./apps/playground/.nuxt/nuxt.d.ts",
    "./apps/playground/.nuxt/nuxt.node.d.ts",
    "./apps/playground/.nuxt/imports.d.ts",
    "./apps/playground/.nuxt/types/*.d.ts",
    "./apps/playground/.nuxt/content/types.d.ts",
    "./layers/*/app/**/*",
    "./tests/**/*",
    "./types/**/*"
  ]
}
