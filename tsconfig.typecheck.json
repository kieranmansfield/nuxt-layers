{
  "extends": "./apps/playground/.nuxt/tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true
  },
  "include": [
    "./apps/playground/.nuxt/nuxt.d.ts",
    "./apps/playground/.nuxt/nuxt.node.d.ts",
    "./apps/playground/.nuxt/imports.d.ts",
    "./apps/playground/.nuxt/types/*.d.ts",
    "./apps/playground/.nuxt/content/types.d.ts",
    "./layers/*/app/**/*"
  ]
}
